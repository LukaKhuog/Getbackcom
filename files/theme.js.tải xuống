    function setCookie(cname, cvalue, exdays) {
        var d = new Date();
        d.setTime(d.getTime() + (exdays * 24 * 60 * 60 * 1000));
        var expires = "expires="+d.toUTCString();
        document.cookie = cname + "=" + cvalue + ";" + expires + ";path=/";
    }
    function getCookie(cname) {
        var name = cname + "=";
        var ca = document.cookie.split(';');
        for(var i = 0; i < ca.length; i++) {
            var c = ca[i];
            while (c.charAt(0) == ' ') {
                c = c.substring(1);
            }
            if (c.indexOf(name) == 0) {
                return c.substring(name.length, c.length);
            }
        }
        return "";
    } 
    function remove_slider_js($tag){
        $tag.find('a').each(function(){
            if($(this).attr('href')!='' && $(this).attr('href')!='#'){
                $tag.find('a').unbind('click');
            }
        });
        $tag.unbind('mouseover');$tag.unbind('mousedown');$tag.unbind('mousemove');$tag.unbind('mouseup');$tag.unbind('mouseleave');
        $tag.unbind('touchstart');$tag.unbind('touchend');$tag.unbind('touchmove');
        $tag.removeAttr('style');
        $tag.removeAttr('data-left');
        $tag.removeAttr('data-mousedown');
        $tag.find('>li').removeAttr('style');
        $tag.parent().find('>.slider-control a').addClass('hide');
        $tag.parent().find('>.dotted_control').remove();
    }
    function slider_js1($tag,items_per_page,margin_right,show_arrow,dotted_control,auto_slide,offset_percent,index_interval,time_interval=6000,speed='normal'){
        if($tag.length==0){
			return;
		}
		$tag.css('touch-action','pan-y');
		var parent_w = $tag.parent().outerWidth();
		var offset_slider_w = parent_w-(parent_w*((100-offset_percent)/100));
		var item_w = (parent_w-((items_per_page-1)*margin_right)-offset_slider_w)/items_per_page;
		var index_iv = $tag.attr('data-ival');
		var index = 0;
		var offset_data_left = 0;
		var tag_child = '>li';
		if($tag.find('>div').length>0){
			tag_child = '>div';
		}
		if($tag.find(tag_child).length>items_per_page){
			if($tag.find(tag_child+'.clone').length==0 && $tag.find(tag_child+'.clone-pre').length==0){
				$tag.find(tag_child).each(function(){
					$(this).attr('data-index',index);
					index++;
				});
			}
			if($tag.find(tag_child).length/items_per_page<3){
				var $preclonetag = [];
				for(var i=0;i<items_per_page;i++){
					$preclonetag.push($tag.find(tag_child+':nth-last-child('+(i+1)+')').clone().addClass('clone'));
				}
				var $apclonetag = [];
				var number_item_last_page = $tag.find(tag_child).length-items_per_page;
				while(number_item_last_page+$tag.find(tag_child).length<2*items_per_page){
					number_item_last_page++;
				}
				while((number_item_last_page+items_per_page)%$tag.find(tag_child).length!=0){
					number_item_last_page++;
				}
				var index = 0;
				for(var i=0;i<number_item_last_page;i++){
					$apclonetag.push($tag.find(tag_child+':nth-child('+(index+1)+')').clone().addClass('clone'));
					index++;
					if(index>$tag.find('>li').length-1){
						index = 0;
					}
				}
				for(var i=0;i<$apclonetag.length;i++){
					$apclonetag[i].appendTo($tag);
				}
				for(var i=0;i<$preclonetag.length;i++){
					$preclonetag[i].prependTo($tag);
					offset_data_left+=item_w+margin_right;
				}
			}else{
				if($tag.find(tag_child+'.clone-pre').length==0){
					for(var i=0;i<items_per_page;i++){
						$tag.find(tag_child+':last-child').addClass('clone-pre');						
						$tag.find(tag_child+':last-child').prependTo($tag);
						offset_data_left+=item_w+margin_right;
					}
				}
			}
		}
		if(index_iv=='' || typeof index_iv=='undefined'){
			index_iv = index_interval;
			$tag.attr('data-ival',index_iv);
		}else{
			index_iv = parseInt(index_iv);
		}
		var ul_w = 0;
		var ul_h = 0;
		$tag.find(tag_child).css('width',item_w);
		$tag.find(tag_child).each(function(){
			ul_w+=item_w+margin_right;
			if(ul_h<$(this).outerHeight()){
				ul_h = $(this).outerHeight();
			}
		});
		$tag.css({'width':ul_w+2,'height':ul_h});
		var index_active = 0;
		var data_left = $tag.attr('data-left');
		if(typeof data_left!='undefined' && data_left!=''){
			data_left = parseInt(data_left);
		}else{
			data_left = 0;
		}
		data_left -=offset_data_left;
		var index_active = Math.round(Math.abs(data_left)/(item_w+margin_right));
		data_left = -index_active*(item_w+margin_right);		
		if($tag.find(tag_child).length>items_per_page){
			if(data_left<-(ul_w-2*(parent_w+margin_right))){
				while(data_left<-(ul_w-2*(parent_w+margin_right))){
					data_left+=(item_w+margin_right);
					$tag.find(tag_child+':first-child').appendTo($tag);
				}
			}else{
				if(data_left>-(parent_w+margin_right)){
					while(data_left>-(parent_w+margin_right)){
						$tag.find(tag_child+':last-child').prependTo($tag);
						data_left-=(item_w+margin_right);
					}
					$tag.attr('data-left',data_left);
				}	
			}
			$tag.parent().find('.slider-control a').removeClass('hide');
		}else{
			$tag.parent().find('.slider-control a').addClass('hide');
		}
		index_active = Math.round(Math.abs(data_left)/(item_w+margin_right));
		$tag.find(tag_child).removeClass('current-active');
		$tag.find(tag_child).each(function(){
			var i = $(this).index();
			if(i>=index_active*items_per_page && i<(index_active+1)*items_per_page){
				$(this).addClass('current-active');
			}
		});
		if(dotted_control){
			if($tag.parent().find('.dotted_control').length>0){
				$tag.parent().find('.dotted_control').remove();
			}
			var items_num = Math.ceil($tag.find(tag_child+':not(.clone)').length/items_per_page);
			if(items_num>1){
				var tag_dotted = '<div class="dotted_control"><ul>';
				for(var i=0;i<items_num;i++){
					tag_dotted+='<li></li>';
				}
				tag_dotted+='</ul></div>';
				$tag.parent().append($(tag_dotted));
				$tag.parent().find('.dotted_control').find('ul li').unbind('click');
				$tag.parent().find('.dotted_control').find('ul li').click(function(e){
					if(!$(this).hasClass('active')){
						var index = $(this).index();
						var current_active = $(this).parent().find('li.active').index();
						var current_data_index = index*items_per_page;
						var current_tag_index = -1;
						data_left = parseFloat($tag.attr('data-left'));
						index_active = Math.round(Math.abs(data_left/(item_w+margin_right)));
						$tag.find(tag_child).each(function(){
							var data_index = parseInt($(this).attr('data-index'));
							if(index>current_active){
								if(data_index==current_data_index && $(this).index()>index_active+items_per_page-1){
									if(current_tag_index==-1){
										current_tag_index = $(this).index();
									}
								}
							}else{
								if(data_index==current_data_index && $(this).index()<index_active){
									if(current_tag_index==-1){
										current_tag_index = $(this).index();
									}
								}
							}
						});
						if(current_tag_index==-1){
							$tag.find(tag_child).each(function(){
								var data_index = parseInt($(this).attr('data-index'));
								if(data_index==current_data_index){
									if(current_tag_index==-1){
										current_tag_index = $(this).index();
									}
								}
							});
							if(index>current_active){
								while(current_tag_index<index_active){
									if(parseInt($tag.find(tag_child+':first-child').attr('data-index'))==current_data_index){
										current_tag_index = $tag.find(tag_child).length-1;
									}else{
										current_tag_index--;
									}
									$tag.find(tag_child+':first-child').appendTo($tag);
									data_left+=item_w+margin_right;
								}
							}else{
								while(current_tag_index>=index_active+items_per_page-1){
									if(parseInt($tag.find(tag_child+':last-child').attr('data-index'))==current_data_index){
										current_tag_index = 0;
									}else{
										current_tag_index++;
									}
									$tag.find(tag_child+':last-child').prependTo($tag);
									data_left-=item_w+margin_right;
								}
							}
						}
						$(this).parent().find('li.active').removeClass('active');
						$(this).addClass('active');
						$tag.css('margin-left',data_left);
						data_left = -current_tag_index*(item_w+margin_right);
						$tag.animate({'margin-left':data_left},speed,'swing',function(){
							if(data_left<-(ul_w-2*(parent_w+margin_right))){
								while(data_left<-(ul_w-2*(parent_w+margin_right))){
									$(this).find(tag_child+':first-child').appendTo($(this));
									data_left+=(item_w+margin_right);
									$(this).css('margin-left',Math.floor(data_left*100)/100);
								}
								$(this).attr('data-left',data_left);
							}else{
								if(data_left>-(parent_w+margin_right)){
									while(data_left>-(parent_w+margin_right)){
										$(this).find(tag_child+':last-child').prependTo($(this));
										data_left-=(item_w+margin_right);
										$(this).css('margin-left',Math.floor(data_left*100)/100);
									}
									$(this).attr('data-left',data_left);
								}
							}
							index_active = Math.round(Math.abs(data_left)/(item_w+margin_right));
							$tag.find(tag_child).removeClass('current-active');
							$tag.find(tag_child).each(function(){
								var i = $(this).index();
								if(i>=index_active*items_per_page && i<(index_active+1)*items_per_page){
									$(this).addClass('current-active');
								}
							});
						});
						$tag.attr('data-left',data_left);
						if(auto_slide){
							clearInterval(ival[index_iv]);
							if($tag.find(tag_child).length>items_per_page){
								ival[index_iv] = setInterval(function(){
									data_left = $tag.attr('data-left');
									if(typeof data_left == 'undefined' || data_left == ''){
										data_left = 0;
									}else{
										data_left = parseFloat(data_left);
									}
									data_left-=item_w+margin_right;
									$tag.attr('data-moving',1);
									$tag.animate({'margin-left':data_left},speed,'swing',function(){
										if(data_left<-(ul_w-2*(parent_w+margin_right))){
											while(data_left<-(ul_w-2*(parent_w+margin_right))){
												$(this).find(tag_child+':first-child').appendTo($(this));
												data_left+=(item_w+margin_right);
												$(this).css('margin-left',Math.floor(data_left*100)/100);
											}
											$(this).attr('data-left',data_left);
										}else{
											if(data_left>-(parent_w+margin_right)){
												while(data_left>-(parent_w+margin_right)){
													$(this).find(tag_child+':last-child').prependTo($(this));
													data_left-=(item_w+margin_right);
													$(this).css('margin-left',Math.floor(data_left*100)/100);
												}
												$(this).attr('data-left',data_left);
											}
										}
										$(this).attr('data-moving','');
										index_active = Math.round(Math.abs(data_left)/(item_w+margin_right));
										$tag.find(tag_child).removeClass('current-active');
										$tag.find(tag_child).each(function(){
											var i = $(this).index();
											if(i>=index_active*items_per_page && i<(index_active+1)*items_per_page){
												$(this).addClass('current-active');
											}
										});
									});
									$tag.attr('data-left',data_left);
									if(dotted_control){
										index_active = Math.round(Math.abs(data_left/(item_w+margin_right)));
										var index_page = parseInt($tag.find(tag_child+':nth-child('+(index_active+1)+')').attr('data-index'));
										index_page = Math.ceil(index_page/items_per_page);
										$tag.parent().find('.dotted_control').find('ul li').removeClass('active');
										$tag.parent().find('.dotted_control').find('ul li:nth-child('+(index_page+1)+')').addClass('active');
									}
								},time_interval);
							}
						}
					}
				});
			}
		}else{
			$tag.parent().find('.dotted_control').remove();
		}
		if(dotted_control){
			index_active = Math.round(Math.abs(data_left/(item_w+margin_right)));
			var index_page = parseInt($tag.find(tag_child+':nth-child('+(index_active+1)+')').attr('data-index'));
			index_page = Math.ceil(index_page/items_per_page);
			$tag.parent().find('.dotted_control').find('ul li').removeClass('active');
			$tag.parent().find('.dotted_control').find('ul li:nth-child('+(index_page+1)+')').addClass('active');
		}
		$tag.css('margin-left',Math.floor(data_left*100)/100);
		$tag.attr('data-left',data_left);
		$tag.find(tag_child+' a').click(function(e){e.preventDefault();});
		$tag.css('visibility','visible');
		$tag.unbind('mousedown');$tag.unbind('mousemove');$tag.unbind('mouseup');$tag.unbind('mouseleave');$tag.unbind('mouseover');
		$tag.mousedown(function(e){
			e.preventDefault();
			var button = e.which || e.button;
			if(button == 1){
				var data_moving = $(this).attr('data-moving');
				if(data_moving=='' || typeof data_moving=='undefined'){
					$tag.attr('data-mousedown',e.pageX);
					if(auto_slide){
						clearInterval(ival[index_iv]);
					}
				}
			}
		});
		$tag.mousemove(function(e){
			e.preventDefault();
			var data_moving = $(this).attr('data-moving');
			if(data_moving=='' || typeof data_moving=='undefined'){
				var data_mousedown = $(this).attr('data-mousedown');
				if(typeof data_mousedown!='undefined' && data_mousedown!=''){
					data_mousedown = parseInt(data_mousedown);
					var data_left = $(this).attr('data-left');
					if(typeof data_left!='undefined' && data_left!=''){
						data_left = parseFloat(data_left);
					}else{
						data_left = 0;
					}
					data_left+=e.pageX-data_mousedown;
					if($tag.find(tag_child).length>items_per_page){
						$(this).css('margin-left',data_left);
					}
				}
			}
		});
		$tag.mouseup(function(e){
			e.preventDefault();
			var data_moving = $(this).attr('data-moving');
			if(data_moving=='' || typeof data_moving=='undefined'){
				var data_mousedown = $(this).attr('data-mousedown');
				if(typeof data_mousedown!='undefined' && data_mousedown!=''){
					data_mousedown = parseInt(data_mousedown);
					var data_left = $(this).attr('data-left');
					if(typeof data_left!='undefined' && data_left!=''){
						data_left = parseFloat(data_left);
					}else{
						data_left = 0;
					}
					var swipe_w = Math.abs(e.pageX-data_mousedown);					
					if(swipe_w>10){	
						if(swipe_w%(item_w+margin_right)>=(item_w+margin_right)/6){
							swipe_w = Math.ceil(swipe_w/(item_w+margin_right))*(item_w+margin_right);
						}else{
							swipe_w = Math.floor(swipe_w/(item_w+margin_right))*(item_w+margin_right);
						}	
						if(e.pageX<data_mousedown){
							swipe_w=-swipe_w;
						}
						data_left+=swipe_w;
					}else{
						if($(this).find(tag_child+' a').length>0){
							var $anchor = $(this).find(tag_child+' a');
							if(Math.abs(e.pageX-data_mousedown)<=10){
								$anchor.each(function(){
									if($(this).attr('href')!='' && $(this).attr('href')!='#'){
										if(e.pageX>=$(this).offset().left && e.pageX<=$(this).offset().left+$(this).outerWidth() && e.pageY>=$(this).offset().top && e.pageY<=$(this).offset().top+$(this).outerHeight()){
											if($(e.target).is($(this)) || $(e.target).is($(this).find('*'))){
												if(!$(this).hasClass('add-to-cart') && !$(this).parent().hasClass('add-to-cart')){
													if($(this).attr('target')=='_blank'){
